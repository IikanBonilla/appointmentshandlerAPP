<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Development.frontend.controller.LoginController"
      spacing="15" alignment="CENTER" style="-fx-background-color: #f0f0f0;">
    
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>
    
    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 30; -fx-border-color: #c0c0c0; -fx-border-width: 1;">
        
        <Label text="Iniciar Sesión" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <Separator prefWidth="200"/>
        
        <TextField fx:id="usernameField" promptText="Usuario" maxWidth="250" prefWidth="250"/>
        <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="250" prefWidth="250"/>
        
        <Label fx:id="statusLabel" text="" style="-fx-text-fill: red; -fx-font-size: 11px;" visible="false"/>
        
        <HBox spacing="10" alignment="CENTER">
            <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="20" maxHeight="20"/>
            <Button fx:id="loginButton" text="Ingresar" onAction="#handleLogin" 
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 5 20 5 20;"/>
        </HBox>
        
        <Label text="usuario: doctor1 / pass: 123" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10px;"/>
        
    </VBox>
</VBox>